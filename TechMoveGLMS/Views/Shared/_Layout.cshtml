<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechMove GLMS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <div class="app-container">

        <!-- ===== SIDEBAR ===== -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h2><i class="fa-solid fa-ship"></i> TechMove</h2>
                <button id="close-sidebar" class="mobile-toggle" style="display:none; color:white;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <p class="nav-section-label">Navigation</p>
            <ul class="nav-links">
                <li>
                    <a href="/">
                        <i class="fa-solid fa-chart-pie"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/Contracts">
                        <i class="fa-solid fa-file-contract"></i> Contracts
                    </a>
                </li>
                <li>
                    <a href="/ServiceRequests">
                        <i class="fa-solid fa-truck-fast"></i> Service Requests
                    </a>
                </li>
                <li>
                    <a href="/Clients">
                        <i class="fa-solid fa-users"></i> Clients
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                © 2026 TechMove Logistics
            </div>
        </nav>

        <!-- ===== MAIN CONTENT ===== -->
        <main class="main-content">
            <header class="top-header">
                <div class="top-header-left">
                    <button id="open-sidebar" class="mobile-toggle">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <span class="breadcrumb-text">@ViewData["Title"]</span>
                </div>

                <div class="user-profile">
                    <span>techMove Admin</span>
                    <div class="avatar">TM</div>
                    <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="fa-solid fa-right-from-bracket"></i> Logout
                        </button>
                    </form>
                </div>
            </header>

            <div class="page-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>